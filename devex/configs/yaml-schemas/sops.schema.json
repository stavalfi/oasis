{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/poc/devex/configs/yaml-schemas/sops.schema.json",
  "title": "sops configuration",
  "description": "Schema for .sops.yaml. Covers age-based encryption rules as used in this repo. See https://github.com/getsops/sops#using-sopsyaml-conf-to-select-kms-pgp-and-age-for-new-files",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "keys": {
      "description": "YAML anchors for reuse. Not consumed by sops itself; this section exists so identities can be referenced by alias inside creation_rules.",
      "type": "array",
      "items": { "$ref": "#/definitions/agePubKey" }
    },
    "creation_rules": {
      "description": "Ordered rules. The first rule whose path_regex matches a new file's path determines the recipients.",
      "type": "array",
      "items": { "$ref": "#/definitions/creationRule" }
    },
    "destination_rules": {
      "description": "Rules applied when publishing decrypted secrets to another store (rare).",
      "type": "array",
      "items": { "type": "object" }
    },
    "stores": {
      "description": "Per-format store configuration (e.g., indent settings for YAML).",
      "type": "object"
    }
  },
  "definitions": {
    "agePubKey": {
      "type": "string",
      "pattern": "^age1[a-z0-9]{58}$",
      "description": "An age recipient public key. Format: age1 followed by 58 lowercase alphanumeric characters."
    },
    "agePubKeyList": {
      "oneOf": [
        { "$ref": "#/definitions/agePubKey" },
        {
          "type": "array",
          "items": { "$ref": "#/definitions/agePubKey" }
        }
      ]
    },
    "creationRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_regex"],
      "properties": {
        "path_regex": {
          "type": "string",
          "description": "Regex matched against the file path of a new sops file."
        },
        "key_groups": {
          "description": "List of key groups; sops requires a threshold of groups to decrypt (default: any one group).",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "age": {
                "type": "array",
                "items": { "$ref": "#/definitions/agePubKey" }
              },
              "pgp": {
                "type": "array",
                "items": { "type": "string" }
              },
              "kms": {
                "type": "array",
                "items": { "type": "object" }
              },
              "gcp_kms": {
                "type": "array",
                "items": { "type": "object" }
              },
              "azure_kv": {
                "type": "array",
                "items": { "type": "object" }
              },
              "hc_vault_transit_uri": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "shamir_threshold": {
          "description": "Number of key_groups required to decrypt (Shamir secret sharing).",
          "type": "integer",
          "minimum": 1
        },
        "age": { "$ref": "#/definitions/agePubKeyList" },
        "pgp": {
          "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }]
        },
        "kms": {
          "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }]
        },
        "gcp_kms": {
          "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }]
        },
        "azure_kv": {
          "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }]
        },
        "hc_vault_transit_uri": {
          "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }]
        },
        "encrypted_suffix": { "type": "string" },
        "unencrypted_suffix": { "type": "string" },
        "encrypted_regex": { "type": "string" },
        "unencrypted_regex": { "type": "string" },
        "mac_only_encrypted": { "type": "boolean" }
      }
    }
  }
}
