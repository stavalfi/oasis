{
  "name": "oasis",
  "private": true,
  "type": "module",
  "imports": {
    "#backend/*": "./backend/src/*",
    "#jira/*": "./backend/jira-client/src/*"
  },
  "scripts": {
    "backend": "node --env-file .env backend/scripts/start.ts",
    "scraper": "node --env-file .env scraper/scripts/start.ts",
    "frontend:build": "vite build",
    "build": "tsc --build",
    "docker-compose:up": "docker compose -f docker-compose.yml up -d --force-recreate",
    "docker-compose:down": "docker compose -f docker-compose.yml down --remove-orphans",
    "e2e": "playwright test --config frontend/playwright.config.ts",
    "codegen": "openapi-ts -f backend/jira-client/openapi-ts.config.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@keyv/redis": "^5.1.6",
    "@reduxjs/toolkit": "^2.12.0",
    "@sesamecare-oss/redlock": "^1.4.0",
    "cache-manager": "^7.2.9",
    "cheerio": "^1.2.0",
    "deep-freeze-es6": "^5.0.0",
    "googleapis": "^173.0.0",
    "hono": "^4.12.25",
    "inversify": "^8.1.0",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "keyv": "^5.6.0",
    "ky": "^2.0.2",
    "kysely": "^0.29.3",
    "match-sorter": "^8.3.0",
    "p-limit": "^7.3.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "react-select": "^5.10.2",
    "undici": "^8.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.13.0",
    "@hey-api/openapi-ts": "^0.98.0",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.0.300",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.9",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "commander": "^14.0.3",
    "commander-js": "^0.0.1-security",
    "kysely-codegen": "^0.20.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
