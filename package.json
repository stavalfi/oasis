{
  "name": "oasis",
  "private": true,
  "type": "module",
  "imports": {
    "#backend/*": "./backend/src/*",
    "#jira/*": "./devex/generated/jira/src/*"
  },
  "scripts": {
    "backend": "bash backend/scripts/start.sh",
    "frontend": "bun --hot frontend/src/index.html",
    "test": "node --test --test-concurrency 8",
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "build:watch": "tsc --build --watch",
    "cli": "node devex/scripts/src/cli/index.ts",
    "codegen": "bun run cli devex codegen",
    "lint": "node devex/scripts/src/lint.ts --fix",
    "lint:check": "node devex/scripts/src/lint.ts",
    "format": "node devex/scripts/src/format.ts",
    "format:check": "node devex/scripts/src/format.ts --check",
    "docker-compose:up": "docker compose -f devex/docker-compose.yml up -d --force-recreate",
    "docker-compose:down": "docker compose -f devex/docker-compose.yml down --remove-orphans",
    "apply-vscode-keybindings": "cp .vscode/keybindings.json ~/.config/Code/User/keybindings.json",
    "postinstall": "node devex/scripts/src/postinstall.ts"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@keyv/redis": "^5.1.6",
    "@reduxjs/toolkit": "^2.12.0",
    "boolean": "^3.2.0",
    "cache-manager": "^7.2.9",
    "deep-freeze-es6": "^5.0.0",
    "googleapis": "^173.0.0",
    "hono": "^4.12.25",
    "inversify": "^8.1.0",
    "ioredis": "^5.11.1",
    "keyv": "^5.6.0",
    "ky": "^2.0.2",
    "kysely": "^0.29.3",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "undici": "^8.4.0",
    "yaml": "^2.9.0",
    "zod": "^4.3.6",
    "zod-tsconfig": "^0.2.0"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@hey-api/client-fetch": "^0.13.0",
    "@hey-api/openapi-ts": "^0.98.0",
    "@types/chrome": "^0.0.300",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.9",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "commander": "^14.0.3",
    "commander-js": "^0.0.1-security",
    "devcert": "^1.2.3",
    "knip": "^6.15.0",
    "kysely-codegen": "^0.20.0",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "prettier": "^3.5.3",
    "tokscale": "^3.0.0",
    "typescript": "^6.0.3"
  }
}
