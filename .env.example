# IdentityHub local configuration. Copy to `.env` and fill in real values.
# `.env` is gitignored; this template is committed.

# Jira (Atlassian) OAuth 2.0 (3LO) app credentials from the Developer Console.
JIRA_CLIENT_ID=your-atlassian-oauth-client-id
JIRA_CLIENT_SECRET=your-atlassian-oauth-client-secret

# Backend
PORT=3000
OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key

# Postgres (also read by devex/docker-compose.yml)
POSTGRES_USER=identityhub
POSTGRES_PASSWORD=identityhub_dev_pw
POSTGRES_DB=identityhub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (also read by devex/docker-compose.yml)
REDIS_PASSWORD=identityhub_dev_pw
REDIS_HOST=localhost
REDIS_PORT=6379
